# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# PostgreSQL connection string (on Vercel this is set automatically by Neon Postgres storage)
DATABASE_URL="postgresql://user:password@host/dbname"

# Secret for signing auth tokens (JWT). Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Atrion AI Pro primary provider. Any OpenAI-compatible API works.
# If OPENAI_API_KEY is empty, the app runs in demo mode with realistic local mock output.
OPENAI_API_KEY=""

# Optional: OpenAI-compatible provider endpoint (e.g. Groq: https://api.groq.com/openai/v1)
OPENAI_BASE_URL=""

# Primary model (for Groq use e.g. llama-3.3-70b-versatile)
OPENAI_MODEL="gpt-4o"

# Optional Atrion AI Pro fallback. Recommended: Gemini from Google AI Studio.
# It is tried automatically when the primary provider has a network,
# rate-limit, provider, or invalid-JSON failure.
AI_FALLBACK_API_KEY=""
AI_FALLBACK_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
AI_FALLBACK_MODEL="gemini-3.5-flash"

# Email verification via https://resend.com
RESEND_API_KEY=""
# Use onboarding@resend.dev for testing. For all users, verify your own domain in Resend.
EMAIL_FROM="Atrion <onboarding@resend.dev>"

# Public application URL used by payment redirects and webhooks
APP_URL="https://atrion-2-0.vercel.app"

# Manual payment fallback (digits only)
PAYMENT_WHATSAPP="996700123456"

# Finik Web SDK. Keep disabled until the beta webhook is verified.
FINIK_ENABLED="false"
FINIK_BASE_URL="https://beta.api.acquiring.averspay.kg"
FINIK_API_KEY=""
FINIK_ACCOUNT_ID=""
FINIK_QR_NAME="Atrion Pro"
# Store PEM values as Sensitive variables in Vercel. Literal \n is supported.
FINIK_PRIVATE_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FINIK_PUBLIC_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
